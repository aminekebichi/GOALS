# ── Secrets & environment ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
nextjs-app/.env
nextjs-app/.env.local

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── ML artifacts (regenerated locally via Python pipeline) ─────────────────
goals_app/ml/artifacts/*.pkl
goals_app/ml/artifacts/*.json

# ── Notebook-produced model artifacts (large pkl files, regenerated by running notebooks) ──
data/models/

# ── FotMob raw JSON cache (large, re-scrape-able) ──────────────────────────
data/47/*/raw/
data/87/*/raw/

# ── FotMob processed parquet/csv (regenerated by scraper) ─────────────────
data/47/*/output/*.parquet
data/47/*/output/*.csv
data/87/*/output/*.parquet
data/87/*/output/*.csv

# Keep FBref CSVs (small, primary source — committed to repo)
!data/FBref/**/*.csv

# ── Svelte frontend build output ───────────────────────────────────────────
frontend/dist/
frontend/.svelte-kit/
frontend/node_modules/

# ── Next.js app ────────────────────────────────────────────────────────────
nextjs-app/.next/
nextjs-app/out/
nextjs-app/node_modules/
nextjs-app/playwright-report/
nextjs-app/test-results/
nextjs-app/scripts/seed_data.json

# ── OS & IDEs ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Course PDFs / HW docs (not part of project functionality) ──────────────
*.pdf
DEVELOPMENT_BREAKDOWN.md
HW4_FINAL_WRITEUP.md
HW4_ Claude Code Workflow & TDD.pdf
hw4_writeup.pdf
HW5_ Custom Skill + MCP Integration.pdf
