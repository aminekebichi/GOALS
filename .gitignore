# FotMob raw match JSON cache (large, re-scrape-able)
data/47/*/raw/
data/87/*/raw/

# Python
__pycache__/
*.py[cod]
*.pyo
.env
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# Large output files (parquet/csv under FotMob output can be re-generated)
data/47/*/output/*.parquet
data/47/*/output/*.csv
data/87/*/output/*.parquet
data/87/*/output/*.csv

# Keep FBref CSVs (small, primary source — committed to repo)
!data/FBref/**/*.csv

# ML artifacts (regenerated locally via train.py)
goals_app/ml/artifacts/*.pkl
goals_app/ml/artifacts/*.json

# Frontend build output
frontend/dist/
frontend/.svelte-kit/
frontend/node_modules/

# HW writeup documents
DEVELOPMENT_BREAKDOWN.md
HW4_FINAL_WRITEUP.md
HW4_ Claude Code Workflow & TDD.pdf
hw4_writeup.pdf
HW5_ Custom Skill + MCP Integration.pdf
