{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/amine/OneDrive/Documents/git_workspace/GOALS/nextjs-app\" && node_modules/.bin/prettier --write \"${CLAUDE_TOOL_INPUT_FILE_PATH}\" --log-level silent 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/amine/OneDrive/Documents/git_workspace/GOALS/nextjs-app\" && node_modules/.bin/eslint \"${CLAUDE_TOOL_INPUT_FILE_PATH}\" --fix --quiet 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/amine/OneDrive/Documents/git_workspace/GOALS/nextjs-app\" && npx vitest run --reporter=verbose 2>&1 | tail -6"
          }
        ]
      }
    ]
  }
}
